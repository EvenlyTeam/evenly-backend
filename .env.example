# DB
DB_USERNAME=evenly
DB_PASSWORD=
DB_HOST=localhost
# Docker 컨테이너로 배포 시 호스트 DB 접근은 host.docker.internal 사용
# DB_HOST=host.docker.internal
DB_PORT=5432
DB_NAME=evenly

# 서버 (컨테이너 내부 포트). 배포 hostPort 매핑은 Jenkinsfile 참고
SERVER_PORT=8080

# JWT — 운영에서는 반드시 별도 시크릿으로 교체(32바이트 이상). 기본값은 로컬 개발용.
JWT_SECRET=change-me-to-a-strong-32-byte-min-secret
# JWT_ACCESS_TOKEN_VALIDITY_MS=3600000
